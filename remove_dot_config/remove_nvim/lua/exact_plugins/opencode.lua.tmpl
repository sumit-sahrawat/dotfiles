{{- if .app.opencode -}}

return {
  {
    "folke/sidekick.nvim",
    opts = {
      nes = {
        enabled = false,
      },
    },
    keys = {
      {
        "<leader>ao",
        function() require("sidekick.cli").toggle({ name = "opencode", focus = true }) end,
        desc = "Sidekick Toggle Opencode",
      },
    }
  },
}

{{- end }}
