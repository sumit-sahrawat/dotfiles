{{- if .app.git -}}

[user]
  name = {{ .git.global.user.name }}
  email = {{ .git.global.user.email }}
  signingkey = {{ .git.global.user.key }}
[core]
  sshCommand = "ssh -i {{ .git.global.user.key | squote }} -o IdentitiesOnly=yes"
  pager = delta
  excludesFile = ~/.config/git/ignore
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true  # use n and N to move between diff sections
  line-numbers = true
  hyperlinks = true
  relative-paths = true
  side-by-side = true
  features = catppuccin-{{ .ui.theme.catppuccin }}
[include]
  path = ~/.config/delta/themes/catppuccin/catppuccin.gitconfig
[merge]
  tool = {{ .tool.merge }}
[mergetool]
  prompt = false
  keepBackup = false
[mergetool {{ .tool.merge | quote }}]
  layout = "LOCAL,BASE,REMOTE / MERGED"
[merge]
  conflictStyle = zdiff3
[diff]
  colorMoved = default
[column]
  ui = auto
[branch]
  sort = -committerdate
[fetch]
  prune = true
[init]
  defaultBranch = main
[rerere]
  enabled = true
[commit]
  gpgsign = true
[gpg]
  format = ssh
[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed_signers
{{- if .git.isolated.enabled }}
{{- range .git.isolated.dirs }}
[includeIf "gitdir:{{ . }}/**"]
  path = ~/.config/git/isolated
{{- end }}
{{- end }}
[include]
  path = ~/.config/git/private

{{- end }}
