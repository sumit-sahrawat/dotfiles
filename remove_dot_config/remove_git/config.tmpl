{{- if .app.git -}}

[core]
  pager = delta
  excludesFile = ~/.config/git/ignore
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true  # use n and N to move between diff sections
  line-numbers = true
  hyperlinks = true
{{- if .app.kitty }}
  hyperlinks-file-link-format = "file://{path}#{line}"
{{- end }}
  relative-paths = true
  features = catppuccin-{{ .ui.theme.catppuccin }}
[include]
  path = ~/.config/delta/themes/catppuccin/catppuccin.gitconfig
[merge]
  tool = {{ .tool.merge }}
[mergetool]
  prompt = false
  keepBackup = false
[mergetool {{ .tool.merge | quote }}]
  layout = "LOCAL,BASE,REMOTE / MERGED"
[merge]
  conflictStyle = zdiff3
[diff]
  external = difft
  colorMoved = default
[column]
  ui = auto
[branch]
  sort = -committerdate
[fetch]
  prune = true
[init]
  defaultBranch = main
[rerere]
  enabled = true
[commit]
  gpgsign = true
[gpg]
  format = ssh
[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed_signers

{{- range $file, $host := dict "codeberg" "codeberg.org" "github" "github.com" }}

[includeIf "hasconfig:remote.*.url:git@{{ $host }}:**/**"]
  path = ~/.config/git/{{ $file }}
[includeIf "hasconfig:remote.*.url:ssh://git@{{ $host }}:**/**"]
  path = ~/.config/git/{{ $file }}
[includeIf "hasconfig:remote.*.url:https://{{ $host }}/**"]
  path = ~/.config/git/{{ $file }}

{{- end }}

{{- if .git.isolated.enabled }}
{{- range .git.isolated.dirs }}

[includeIf "gitdir:{{ . }}/**"]
  path = ~/.config/git/isolated

{{- end }}
{{- end }}

[include]
  path = ~/.config/git/private

{{- end }}
