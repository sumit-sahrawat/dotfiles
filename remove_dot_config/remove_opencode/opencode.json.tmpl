{{- if .app.opencode -}}

{{- $enabled_providers := list -}}

{{- if .ai.local.models -}}
  {{- $enabled_providers = append $enabled_providers .ai.local.provider.id -}}
{{- end -}}

{{- if .ai.cloud.models -}}
  {{- $enabled_providers = append $enabled_providers .ai.cloud.provider.id -}}
{{- end -}}

{{- $providers := dict -}}

{{- if .ai.local.models -}}

  {{- $local_models := dict -}}
  {{- range .ai.local.models -}}
    {{- $config := dict -}}
    {{- if hasKey . "name" -}}
      {{- $config = set $config "name" .name -}}
    {{- end -}}
    {{- $local_models = set $local_models .id $config -}}
  {{- end -}}

  {{- $providers = set $providers .ai.local.provider.id (dict
        "npm" "@ai-sdk/openai-compatible"
        "name" .ai.local.provider.name
        "options" (dict "baseURL" (printf "http://localhost:%d/v1" .ai.local.provider.port ))
        "models" $local_models
  )
  -}}

{{- end -}}

{{- if .ai.local.models -}}

  {{- $local_models := dict -}}
  {{- range .ai.local.models -}}
    {{- $config := dict -}}
    {{- if hasKey . "name" -}}
      {{- $config = set $config "name" .name -}}
    {{- end -}}
    {{- $local_models = set $local_models .id $config -}}
  {{- end -}}

  {{- $providers = set $providers .ai.local.provider.id (dict
        "npm" "@ai-sdk/openai-compatible"
        "name" .ai.local.provider.name
        "options" (dict "baseURL" (printf "http://localhost:%d/v1" .ai.local.provider.port))
        "models" $local_models
      )
  -}}

{{- end -}}

{{- if .ai.cloud.models -}}

  {{- $cloud_models := dict -}}
  {{- range .ai.cloud.models -}}
    {{- $config := dict -}}
    {{- if hasKey . "name" -}}
      {{- $config = set $config "name" .name -}}
    {{- end -}}
    {{- $cloud_models = set $cloud_models .id $config -}}
  {{- end -}}

  {{- $providers = set $providers .ai.cloud.provider.id (dict
        "npm" "@ai-sdk/openai-compatible"
        "name" .ai.cloud.provider.name
        "options" (dict
          "baseURL" .ai.cloud.provider.url
          "apiKey" .ai.cloud.provider.key
        )
        "models" $cloud_models
      )
  -}}

{{- end -}}

{{- $mcp := dict -}}

{{- if .app.searxng -}}
  {{- $mcp = set $mcp "SearXNG" (dict
        "type" "remote"
        "url" (printf "http://localhost:%d/mcp" .searxng.mcp.port)
      )
  -}}
{{- end -}}

{{- $result := dict
      "$schema" "https://opencode.ai/config.json"
      "theme" (printf "catppuccin-%s" .ui.theme.catppuccin)
      "enabled_providers" $enabled_providers
      "keybinds" (dict "command_list" "<leader>p")
      "provider" $providers
      "mcp" $mcp
}}

{{- $result | toPrettyJson -}}

{{- end }}
