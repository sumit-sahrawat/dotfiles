{{- if .app.opencode -}}

{{- $sep := ternary "," "" (and (not (empty .ai.local.models)) (and (not (empty .ai.cloud.models)))) }}

{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin-{{ .ui.theme.catppuccin }}",
  "enabled_providers": [
{{- if .ai.local.models }}
    {{ .ai.local.provider.id | quote }} {{- $sep }}
{{- end }}
{{- if .ai.cloud.models }}
    {{ .ai.cloud.provider.id | quote }}
{{- end }}
  ],
  "keybinds": {
    "command_list": "alt+p",
  },
  "provider": {

{{- if .ai.local.models }}

{{- $local_models := dict }}
{{- range .ai.local.models }}
{{- $local_models = set $local_models .id (dict) }}
{{- end }}
    {{ .ai.local.provider.id | quote }}: {
      "npm": "@ai-sdk/openai-compatible",
      "name": {{ .ai.local.provider.name | quote }},
      "options": {
        "baseURL": {{ printf "http://localhost:%d/v1" .ai.local.provider.port | quote }},
      },
      "models": {{ $local_models | toJson }}
    } {{- $sep }}

{{- end }}

{{- if .ai.cloud.models }}

{{- $cloud_models := dict }}
{{- range .ai.cloud.models }}
{{- $cloud_models = set $cloud_models .id (dict) }}
{{- end }}
    {{ .ai.cloud.provider.id | quote }}: {
      "npm": "@ai-sdk/openai-compatible",
      "name": {{ .ai.cloud.provider.name | quote }},
      "options": {
        "baseURL": {{ .ai.cloud.provider.url | quote }},
        "key": {{ .ai.cloud.provider.key | quote }}
      },
      "models": {{ $cloud_models | toJson }}
    }

{{- end }}
  },
  "mcp": {
{{- if .app.searxng }}
    "SearXNG": {
      "type": "remote",
      "url": "http://localhost:{{ .searxng.mcp.port }}/mcp"
    }
{{- end }}
  }
}

{{- end }}
