{{- if .app.opencode -}}

{{- $provider_id := "local" -}}

{{- $models := dict -}}
{{- range .llama.models -}}
  {{- $config := dict -}}
  {{- if hasKey . "name" -}}
    {{- $config = set $config "name" .name -}}
  {{- end -}}
  {{- $models = set $models .id $config -}}
{{- end -}}

{{- $providers := dict $provider_id (dict
      "npm" "@ai-sdk/openai-compatible"
      "name" "llama.cpp"
      "options" (dict "baseURL" (printf "http://localhost:%d/v1" (int .llama.port)))
      "models" $models
    )
-}}

{{- $mcp := dict -}}
{{- if .app.searxng -}}
  {{- $mcp = set $mcp "SearXNG" (dict
        "type" "remote"
        "url" (printf "http://localhost:%d/mcp" (int .searxng.mcp.port))
      )
  -}}
{{- end -}}

{{- $result := dict
      "$schema" "https://opencode.ai/config.json"
      "theme" (printf "catppuccin-%s" .ui.theme.catppuccin)
      "enabled_providers" (list $provider_id)
      "keybinds" (dict "command_list" "<leader>p")
      "provider" $providers
      "mcp" $mcp
-}}

{{ $result | toPrettyJson }}

{{- end }}
