{{- if ne .chezmoi.os "darwin" -}}
{{-     writeToStdout "[dotfiles] We only support MacOS. Aborting.\n" -}}
{{-     exit 1 -}}
{{- end -}}

[data]

input.keyboard.caps2ctrl = {{ default true (index . "input.keyboard.caps2ctrl") }}
input.keyboard.repeat.delay = 195
input.keyboard.repeat.interval = 15

input.mouse.linear = {{ default true (index . "input.mouse.linear") }}

ui.theme.catppuccin.light = "latte"
ui.theme.catppuccin.dark = "macchiato"

# auto / light / dark
ui.theme.choice = {{ $theme_choice := default "auto" (index . "ui.theme.choice") }}{{ $theme_choice | quote }}
ui.theme.is_auto = {{ eq $theme_choice "auto" }}

ui.dock.tilesize = {{ default 48 (index . "ui.dock.tilesize") }}

app.zsh = {{ default true (index . "app.zsh") }}
app.git = {{ $git := default true (index . "app.git") }}{{ $git }}
app.kitty = {{ $kitty := default true (index . "app.kitty") }}{{ $kitty }}
app.1password = {{ default true (index . "app.1password") }}
app.bat = {{ default true (index . "app.bat") }}
app.chatgpt = {{ default true (index . "app.chatgpt") }}
app.docker = {{ default true (index . "app.docker") }}
app.eza = {{ default true (index . "app.eza") }}
app.fd = {{ default true (index . "app.fd") }}
app.mpv = {{ default true (index . "app.mpv") }}
app.neovim = {{ default true (index . "app.neovim") }}
app.obsidian = {{ default true (index . "app.obsidian") }}
app.procs = {{ default true (index . "app.procs") }}
app.qalc = {{ default true (index . "app.qalc") }}
app.ripgrep = {{ default true (index . "app.ripgrep") }}
app.sd = {{ default true (index . "app.sd") }}

{{- if $git }}

{{- $default_name := "Sumit Sahrawat" }}
{{- $default_email := "139506625+sumit-sahrawat@users.noreply.github.com" }}
{{- $default_key_name := "id_ed25519" }}
{{- $ssh_dir := joinPath .chezmoi.homeDir ".ssh" }}

git.global.user.name = {{ default $default_name (index . "git.global.user.name") | quote }}
git.global.user.email = {{ default $default_email (index . "git.global.user.email") | quote }}
git.global.user.key_name = {{ $global_key_name := default $default_key_name (index . "git.global.user.key_name") }}{{ $global_key_name | quote }}
git.global.user.key = {{ joinPath $ssh_dir $global_key_name | quote }}

git.work.enabled = {{ $git_work := promptBoolOnce . "git.work.enabled" "Use a separate git directory for work" }}{{ $git_work }}

{{- if $git_work }}

git.work.user.name = {{ default $default_name (index . "git.work.user.name") | quote }}
git.work.user.email = {{ promptStringOnce . "git.work.user.email" "Committer email address for work" | quote }}
git.work.user.key_name = {{ $work_key_name := promptStringOnce . "git.work.user.key_name" "SSH key name for work" }}{{ $work_key_name | quote }}
git.work.user.key = {{ joinPath $ssh_dir $work_key_name | quote }}

{{- end }}

{{- end }}

{{- if $kitty }}

kitty.font.pragmata = {{ $pragmata := default true (index . "kitty.font.pragmata") }}{{ $pragmata }}
kitty.font.family = {{ ternary "PragmataPro Mono Liga" "Iosevka Term SS08" $pragmata | quote }}
kitty.font.size = {{ default 16 (index . "kitty.font.size") }}

{{- end }}
