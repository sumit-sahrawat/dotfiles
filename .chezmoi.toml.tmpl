{{- if ne .chezmoi.os "darwin" -}}
{{-     writeToStdout "[dotfiles] We only support MacOS. Aborting.\n" -}}
{{-     exit 1 -}}
{{- end -}}

[data]

################################################################################
# INPUT
################################################################################

input.keyboard.caps2ctrl = {{ dig "input" "keyboard" "caps2ctrl" true . }}
input.keyboard.repeat.delay = 195
input.keyboard.repeat.interval = 15

input.mouse.linear = {{ dig "input" "mouse" "linear" true . }}

################################################################################
# UI
################################################################################

ui.theme.catppuccin.light = {{ dig "ui" "theme" "catppuccin" "light" "latte" . | quote }}
ui.theme.catppuccin.dark = {{ dig "ui" "theme" "catppuccin" "dark" "macchiato" . | quote }}

# dark / light / auto
ui.theme.choice = {{ $theme_choice := dig "ui" "theme" "choice" "dark" . }}{{ $theme_choice | quote }}
ui.theme.is_auto = {{ eq $theme_choice "auto" }}

ui.night_shift.enabled = {{ dig "ui" "night_shift" "enabled" true . }}
ui.night_shift.temperature = {{ dig "ui" "night_shift" "temperature" 50 . }}

ui.dock.tilesize = {{ dig "ui" "dock" "tilesize" 48 . }}

################################################################################
# Apps
################################################################################

app.1password = {{ dig "app" "1password" true . }}

app.anki = {{ dig "app" "anki" true . }}

app.bat = {{ dig "app" "bat" true . }}

app.docker = {{ dig "app" "docker" true . }}

app.eza = {{ dig "app" "eza" true . }}

app.fd = {{ dig "app" "fd" true . }}

app.ghostty = {{ $ghostty := dig "app" "ghostty" true . }}{{ $ghostty }}

app.git = {{ $git := dig "app" "git" true . }}{{ $git }}

{{- if $git }}

{{- $default_name := "Sumit Sahrawat" }}
{{- $default_email := "139506625+sumit-sahrawat@users.noreply.github.com" }}
{{- $default_key_name := "id_ed25519" }}
{{- $ssh_dir := joinPath .chezmoi.homeDir ".ssh" }}

git.global.user.name = {{ dig "git" "global" "user" "name" $default_name . | quote }}
git.global.user.email = {{ dig "git" "global" "user" "email" $default_email . | quote }}
git.global.user.key_name = {{ $global_key_name := dig "git" "global" "user" "key_name" $default_key_name . }}{{ $global_key_name | quote }}
git.global.user.key = {{ joinPath $ssh_dir $global_key_name | quote }}

git.work.enabled = {{ $git_work := promptBoolOnce . "git.work.enabled" "Use a separate git directory for work" }}{{ $git_work }}

{{- if $git_work }}

git.work.user.name = {{ dig "git" "work" "user" "name" $default_name . | quote }}
git.work.user.email = {{ promptStringOnce . "git.work.user.email" "Committer email address for work" | quote }}
git.work.user.key_name = {{ $work_key_name := promptStringOnce . "git.work.user.key_name" "SSH key name for work" }}{{ $work_key_name | quote }}
git.work.user.key = {{ joinPath $ssh_dir $work_key_name | quote }}

{{- end }}

{{- end }}

app.helium = {{ dig "app" "helium" true . }}

app.jq = {{ dig "app" "jq" true . }}

app.kitty = {{ $kitty := dig "app" "kitty" true . }}{{ $kitty }}

app.mpv = {{ dig "app" "mpv" true . }}

app.neovim = {{ dig "app" "neovim" true . }}

app.obsidian = {{ dig "app" "obsidian" true . }}

app.procs = {{ dig "app" "procs" true . }}

app.ripgrep = {{ dig "app" "ripgrep" true . }}

app.sd = {{ dig "app" "sd" true . }}

app.zsh = {{ dig "app" "zsh" true . }}

has.terminal = {{ $has_terminal := or $ghostty $kitty }}{{ $has_terminal }}

{{- if $has_terminal }}

terminal.font.pragmata = {{ $pragmata := dig "terminal" "font" "pragmata" true . }}{{ $pragmata }}
terminal.font.family = {{ ternary "PragmataPro Mono Liga" "Iosevka Term SS08" $pragmata | quote }}
terminal.font.size = {{ dig "terminal" "font" "size" 16 . }}

{{- end }}

################################################################################
# Programming Languages
################################################################################

lang.java = {{ dig "lang" "java" false . }}
lang.python = {{ dig "lang" "python" false . }}
lang.rust = {{ dig "lang" "rust" false . }}
