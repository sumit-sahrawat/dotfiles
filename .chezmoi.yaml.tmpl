{{- $graphical := dig "graphical" (eq .chezmoi.os "darwin") . -}}
{{- $keyboard := dig "keyboard" "mac" . -}}

{{- $neovim := dig "app" "neovim" true . -}}

{{- if $neovim -}}

merge:
  command: "nvim"
  args: [ {{- list "-d" "{{ .Destination }}" "{{ .Source }}" "{{ .Target }}" | quoteList | join ", " -}} ]

{{- end }}

diff:
  pager: "delta"

data:
{{- if eq .chezmoi.os "darwin" }}
  homebrew:
    prefix: "/opt/homebrew"
{{- end }}

  graphical: {{ $graphical }}

  input:
    keyboard:
      type: {{ $keyboard | quote }}
{{- if $graphical }}
      caps2ctrl: {{ dig "input" "keyboard" "caps2ctrl" true . }}
      repeat:
        delay: 195
        interval: 15
    mouse:
      linear: {{ dig "input" "mouse" "linear" true . }}
{{- end }}

  ui:
    theme:

      {{- $catppuccin := dig "ui" "theme" "catppuccin" "macchiato" . }}
      catppuccin: {{ $catppuccin | quote }}

      {{- $is_dark := ne $catppuccin "latte" }}
      is_dark: {{ $is_dark }}

{{- if $graphical }}

    night_shift:
      enabled: {{ dig "ui" "night_shift" "enabled" true . }}
      temperature: {{ dig "ui" "night_shift" "temperature" 100 . }}

    dock:
      tilesize: {{ dig "ui" "dock" "tilesize" 48 . }}

{{- end }}

  app:
    brave: {{ and $graphical (dig "app" "brave" true .) }}

    {{- $claude_code := dig "app" "claude_code" true . }}
    claude_code: {{ $claude_code }}
    direnv: {{ dig "app" "direnv" true . }}

    {{- $ghostty := and $graphical (dig "app" "ghostty" true .) }}
    ghostty: {{ $ghostty }}

    {{- $git := dig "app" "git" true . }}
    git: {{ $git }}

    {{- $kitty := and $graphical (dig "app" "kitty" true .) }}
    kitty: {{ $kitty }}

    {{- $llama := and $graphical (dig "app" "llama" true .) }}
    llama: {{ $llama }}
    mpv: {{ and $graphical (dig "app" "mpv" true .) }}
    neovim: {{ $neovim }}
    obsidian: {{ and $graphical (dig "app" "obsidian" true .) }}

    {{- $opencode := and $llama (dig "app" "opencode" true .) }}
    opencode: {{ $opencode }}

    {{- $terminal := or $kitty $ghostty }}
    terminal: {{ $terminal }}
    zsh: {{ dig "app" "zsh" true . }}

  lang:
    bash: {{ dig "lang" "bash" true . }}
    cpp: {{ dig "lang" "cpp" true . }}
    groovy: {{ dig "lang" "groovy" true . }}
    java: {{ dig "lang" "java" true . }}
    javascript: {{ dig "lang" "javascript" true . }}
    jq: {{ dig "lang" "jq" true . }}
    odin: {{ dig "lang" "odin" true . }}
    python: {{ dig "lang" "python" true . }}
    rust: {{ dig "lang" "rust" true . }}
    zig: {{ dig "lang" "zig" true . }}

  tool:
    editor: {{ ternary "nvim" "vim" $neovim | quote }}
    merge: {{ ternary "nvimdiff" "vimdiff" $neovim | quote }}

{{- if $claude_code }}

  claude_code:
    latest: {{ dig "claude_code" "latest" true . }}
    settings:
      $schema: "https://json.schemastore.org/claude-code-settings.json"
      cleanupPeriodDays: 30
      includeCoAuthoredBy: false
      env:
        DISABLE_BUG_COMMAND: "1"
        DISABLE_ERROR_REPORTING: "1"
        DISABLE_TELEMETRY: "1"
{{ dict "overrides" (dig "claude_code" "overrides" (dict) .) | toYaml | trim | indent 4 }}

{{- end }}

{{- if $git }}

  git:
    alias:
      prefix: {{ dig "git" "alias" "prefix" ":g" . | quote }}

{{- $default_name := "Sumit Sahrawat" }}
{{- $ssh_dir := joinPath .chezmoi.homeDir ".ssh" }}

    codeberg:
      name: {{ dig "git" "codeberg" "name" "Sumit Sahrawat" . | quote }}
      email: {{ dig "git" "codeberg" "email" "sumit-sahrawat@noreply.codeberg.org" . | quote }}
      key_name: {{ $codeberg_key_name := dig "git" "codeberg" "key_name" "id_ed25519" . }}{{ $codeberg_key_name | quote }}
      key: {{ joinPath $ssh_dir $codeberg_key_name | quote }}

    github:
      name: {{ dig "git" "github" "name" "Sumit Sahrawat" . | quote }}
      email: {{ dig "git" "github" "email" "139506625+sumit-sahrawat@users.noreply.github.com" . | quote }}
      key_name: {{ $github_key_name := dig "git" "github" "key_name" "id_ed25519" . }}{{ $github_key_name | quote }}
      key: {{ joinPath $ssh_dir $github_key_name | quote }}

    isolated:

      {{- $git_isolated := promptBoolOnce . "git.isolated.enabled" "Use isolated directories for git" }}
      enabled: {{ $git_isolated }}

{{- if $git_isolated }}

{{ dict "dirs" (dig "git" "isolated" "dirs" (list) .) | toYaml | trim | indent 6 }}
      user:
        name: {{ dig "git" "isolated" "user" "name" $default_name . | quote }}
        email: {{ promptStringOnce . "git.isolated.user.email" "Committer email address for isolated dirs" | quote }}

        {{- $isolated_key_name := promptStringOnce . "git.isolated.user.key_name" "SSH key name for isolated dirs" }}
        key_name: {{ $isolated_key_name | quote }}
        key: {{ joinPath $ssh_dir $isolated_key_name | quote }}

{{- end }}

{{- end }}

{{- if $llama }}

  llama:
    port: {{ dig "llama" "port" 42000 . }}
    idle_timeout: {{ dig "llama" "idle_timeout" 300 . }}

{{ dict "models" (dig "llama" "models" (list) .) | toYaml | trim | indent 4 }}

{{- end }}

{{- if and $graphical $terminal }}

  terminal:
    font:
      pragmata: {{ $pragmata := dig "terminal" "font" "pragmata" true . }}{{ $pragmata }}
      family: {{ ternary "PragmataPro Mono Liga" "Iosevka Term SS08" $pragmata | quote }}
      size: {{ dig "terminal" "font" "size" 15 . }}

{{- end }}
