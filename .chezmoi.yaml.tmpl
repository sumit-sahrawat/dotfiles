{{- $graphical := dig "graphical" (eq .chezmoi.os "darwin") . -}}
{{- $keyboard := dig "keyboard" "mac" . -}}

{{- $neovim := dig "app" "neovim" true . -}}

{{- if $neovim -}}

merge:
  command: "nvim"
  args: [ {{- list "-d" "{{ .Destination }}" "{{ .Source }}" "{{ .Target }}" | quoteList | join ", " -}} ]

{{- end }}

diff:
  pager: "delta"

data:
{{- if eq .chezmoi.os "darwin" }}
  homebrew:
    prefix: "/opt/homebrew"
{{- end }}

  graphical: {{ $graphical }}

  input:
    keyboard:
      type: {{ $keyboard | quote }}
{{- if $graphical }}
      caps2ctrl: {{ dig "input" "keyboard" "caps2ctrl" true . }}
      repeat:
        delay: 195
        interval: 15
    mouse:
      linear: {{ dig "input" "mouse" "linear" true . }}
{{- end }}

  ui:
    theme:

      {{- $catppuccin := dig "ui" "theme" "catppuccin" "macchiato" . }}
      catppuccin: {{ $catppuccin | quote }}

      {{- $is_dark := ne $catppuccin "latte" }}
      is_dark: {{ $is_dark }}

{{- if $graphical }}

    night_shift:
      enabled: {{ dig "ui" "night_shift" "enabled" true . }}
      temperature: {{ dig "ui" "night_shift" "temperature" 100 . }}

    dock:
      tilesize: {{ dig "ui" "dock" "tilesize" 48 . }}

{{- end }}

  app:
    brave: {{ and $graphical (dig "app" "brave" true .) }}

    {{- $claude_code := dig "app" "claude_code" true . }}
    claude_code: {{ $claude_code }}
    direnv: {{ dig "app" "direnv" true . }}

    {{- $ghostty := and $graphical (dig "app" "ghostty" true .) }}
    ghostty: {{ $ghostty }}

    {{- $git := dig "app" "git" true . }}
    git: {{ $git }}

    {{- $kitty := and $graphical (dig "app" "kitty" true .) }}
    kitty: {{ $kitty }}

    mpv: {{ and $graphical (dig "app" "mpv" true .) }}
    neovim: {{ $neovim }}
    obsidian: {{ and $graphical (dig "app" "obsidian" true .) }}

    {{- $terminal := or $kitty $ghostty }}
    terminal: {{ $terminal }}

    {{- $tmux := dig "app" "tmux" true . }}
    tmux: {{ $tmux }}
    zsh: {{ dig "app" "zsh" true . }}

  lang:
    bash: {{ dig "lang" "bash" false . }}
    cpp: {{ dig "lang" "cpp" false . }}
    groovy: {{ dig "lang" "groovy" false . }}
    java: {{ dig "lang" "java" false . }}
    javascript: {{ dig "lang" "javascript" false . }}
    jq: {{ dig "lang" "jq" false . }}
    odin: {{ dig "lang" "odin" false . }}
    python: {{ dig "lang" "python" false . }}
    rust: {{ dig "lang" "rust" false . }}
    zig: {{ dig "lang" "zig" false . }}

  tool:
    editor: {{ ternary "nvim" "vim" $neovim | quote }}
    merge: {{ ternary "nvimdiff" "vimdiff" $neovim | quote }}

{{- if $claude_code }}

  claude_code:
    latest: {{ dig "claude_code" "latest" true . }}
    defaults:
      $schema: "https://json.schemastore.org/claude-code-settings.json"
      cleanupPeriodDays: 30
      includeCoAuthoredBy: false
      env:
        DISABLE_BUG_COMMAND: "1"
        DISABLE_ERROR_REPORTING: "1"
        DISABLE_TELEMETRY: "1"
      enabledPlugins:
        superpowers-extended-cc@superpowers-extended-cc-marketplace: true
      extraKnownMarketplaces:
        superpowers-extended-cc-marketplace:
          source:
            repo: pcvelz/superpowers
            source: github
      hooks:
        PreToolUse:
        - hooks:
          - command: bash ~/.claude/plugins/marketplaces/superpowers-extended-cc-marketplace/hooks/examples/pre-commit-check-tasks.sh
            type: command
          matcher: Bash
        Stop:
        - hooks:
          - command: bash ~/.claude/plugins/marketplaces/superpowers-extended-cc-marketplace/hooks/examples/stop-deflection-guard.sh
            type: command
          matcher: ""
      permissions:
        deny:
        - EnterPlanMode
{{ dict "overrides" (dig "claude_code" "overrides" (dict) .) | toYaml | trim | indent 4 }}

{{- end }}

{{- if $git }}

  git:
    alias:
      prefix: {{ dig "git" "alias" "prefix" ":g" . | quote }}
    default:
      name: {{ dig "git" "default" "name" "Sumit Sahrawat" . | quote }}
      email: {{ dig "git" "default" "email" "" . | quote }}
      key: {{ dig "git" "default" "key" "" . | quote }}

{{- $default_rules := list
  (dict
    "name" "github"
    "user" (dict
      "email" "139506625+sumit-sahrawat@users.noreply.github.com"
      "key" "id_ed25519"
    )
    "match" (dict
      "host" "github.com"
    )
  )
  (dict
    "name" "codeberg"
    "user" (dict
      "email" "sumit-sahrawat@noreply.codeberg.org"
      "key" "id_ed25519"
    )
    "match" (dict
      "host" "codeberg.org"
    )
  )
}}

{{- $rules := dig "git" "rules" nil . }}
{{- if eq $rules nil }}{{ $rules = $default_rules }}{{ end }}

{{ dict "rules" $rules | toYaml | trim | indent 4 }}

{{- end }}

{{- if and $graphical $terminal }}

  terminal:
    font:
      pragmata: {{ $pragmata := dig "terminal" "font" "pragmata" true . }}{{ $pragmata }}
      family: {{ ternary "PragmataPro Mono Liga" "Iosevka Term SS08" $pragmata | quote }}
      size: {{ dig "terminal" "font" "size" 15 . }}

{{- end }}

{{- if $tmux }}

  tmux:
    autostart: {{ dig "tmux" "autostart" (not $graphical) . }}

{{- end }}
