#!/usr/bin/env bash

set -euo pipefail

if ! hash brew >/dev/null; then
	bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

{ sort -u | brew bundle --no-upgrade --file=/dev/stdin; } <<-EOF
	{{- if .input.mouse.linear }}
		cask "homebrew/cask/linearmouse"
	{{- end }}

	{{- if .app.zsh }}
		brew "fzf"
		brew "catppuccin/tap/whiskers"
	{{- end }}

	{{- if .app.git }}
		brew "git"
		brew "git-delta"
		brew "git-ignore"
		brew "gh"
		brew "lazygit"
	{{- end }}

	{{- if .app.kitty }}
		cask "homebrew/cask/kitty"
	{{- end }}

	{{- if and .app.kitty (not .kitty.font.pragmata) }}
		cask "homebrew/cask-fonts/font-iosevka-ss08"
	{{- end }}

	{{- if index .app "1password" }}
		cask "homebrew/cask/1password"
	{{- end }}

	{{- if .app.bandwhich }}
		brew "bandwhich"
	{{- end }}

	{{- if .app.brave }}
		cask "homebrew/cask/brave-browser"
	{{- end }}

	{{- if .app.bat }}
		brew "bat"
	{{- end }}

	{{- if .app.bottom }}
		brew "bottom"
	{{- end }}

	{{- if .app.chatgpt }}
		cask "homebrew/cask/chatgpt"
	{{- end }}

	{{- if .app.docker }}
		cask "homebrew/cask/docker"
	{{- end }}

	{{- if .app.duf }}
		brew "duf"
	{{- end }}

	{{- if .app.dust }}
		brew "dust"
	{{- end }}

	{{- if .app.eza }}
		brew "eza"
	{{- end }}

	{{- if .app.fd }}
		brew "fd"
	{{- end }}

	{{- if .app.hyperfine }}
		brew "hyperfine"
	{{- end }}

	{{- if .app.mpv }}
		brew "mpv"
		brew "yt-dlp"
		brew "aria2"
	{{- end }}

	{{- if .app.neovim }}
		brew "neovim"
	{{- end }}

	{{- if .app.obsidian }}
		cask "homebrew/cask/obsidian"
		cask "homebrew/cask/font-overpass"
	{{- end }}

	{{- if .app.ollama }}
		brew "ollama"
	{{- end }}

	{{- if .app.procs }}
		brew "procs"
	{{- end }}

	{{- if .app.presenterm }}
		brew "presenterm"
	{{- end }}

	{{- if .app.qalc }}
		brew "libqalculate"
	{{- end }}

	{{- if .app.ripgrep }}
		brew "ripgrep"
	{{- end }}

	{{- if .app.sd }}
		brew "sd"
	{{- end }}

	{{- if .app.tealdeer }}
		brew "tealdeer"
	{{- end }}

	{{- if .app.tokei }}
		brew "tokei"
	{{- end }}

	{{- if .lang.cpp }}
		brew "llvm"
		brew "clang-format"
	{{- end }}

	{{- if .lang.dotnet }}
		cask "homebrew/cask/dotnet-sdk"
	{{- end }}

	{{- if .lang.go }}
		brew "go"
	{{- end }}

	{{- if .lang.haskell }}
		brew "haskell-stack"
	{{- end }}

	{{- if .lang.python }}
		brew "uv"
	{{- end }}

	{{- if .lang.ruby }}
		brew "solargraph"
	{{- end }}

	{{- if .lang.rust }}
		brew "rustup"
	{{- end }}

	{{- if .lang.zig }}
		brew "zig"
		brew "zigmod"
		brew "zigup"
		brew "zls"
	{{- end }}
EOF
