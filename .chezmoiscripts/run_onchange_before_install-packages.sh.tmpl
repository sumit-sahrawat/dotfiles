#!/usr/bin/env bash

set -euo pipefail

if ! hash brew >/dev/null; then
  bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

brew bundle --file=/dev/stdin --no-upgrade --quiet <<EOF

################################################################################
# Core CLI Tools
################################################################################

  brew "bat"
  brew "btop"
  brew "delta"
  brew "difftastic"
  brew "duf"
  brew "dust"
  brew "eza"
  brew "fd"
  brew "fzf"
  brew "imagemagick"
  brew "just"
  brew "mprocs"
  brew "numbat"
  brew "procs"
  brew "ripgrep"
  brew "sd"
  brew "vivid"
  brew "yazi"

  tap "rami3l/tap"
  brew "rami3l/tap/pacaptr"

################################################################################
# INPUT
################################################################################

{{- if .input.mouse.linear }}
  cask "linearmouse"
{{- end }}

################################################################################
# UI
################################################################################

{{- if .ui.night_shift.enabled }}
  tap "smudge/smudge"
  brew "smudge/smudge/nightlight"
{{- end }}

################################################################################
# Apps
################################################################################

{{- if .app.brave }}
  cask "brave-browser"
{{- end }}

{{- if .app.claude_code }}
  cask {{ ternary "claude-code@latest" "claude-code" .claude_code.latest | quote }}
{{- end }}

{{- if .app.direnv }}
  brew "direnv"
{{- end }}

{{- if .app.ghostty }}
  cask "ghostty"
{{- end }}

{{- if .app.kitty }}
  cask "kitty"
{{- end }}

{{- if and .app.terminal (not .terminal.font.pragmata) }}
  cask "font-iosevka-ss08"
{{- end }}

{{- if .app.git }}
  brew "git"
  brew "codeberg-cli"
  brew "gh"
  brew "lazygit"
{{- end }}

{{- if .app.llama }}
  brew "llama.cpp"
{{- end }}

{{- if .app.opencode }}
  brew "opencode"
{{- end }}

{{- if .app.mpv }}
  brew "mpv"
  brew "yt-dlp"
  brew "aria2"
{{- end }}

{{- if .app.neovim }}
  brew "neovim"
  brew "tree-sitter-cli"
  brew "node"
{{- end }}

{{- if .app.obsidian }}
  cask "obsidian"
  cask "font-overpass"
{{- end }}

################################################################################
# Programming Languages
################################################################################

{{- if .lang.bash }}
  brew "bash"
{{- end }}

{{- if .lang.cpp }}
  brew "cmake"
  brew "meson"
{{- end }}

{{- if .lang.groovy }}
  brew "groovysdk"
{{- end }}

{{- if .lang.java }}
  brew "maven"
  brew "openjdk"
{{- end }}

{{- if .lang.javascript }}
  brew "node"
  brew "npm"
{{- end }}

{{- if .lang.jq }}
  brew "jq"
{{- end }}

{{- if .lang.odin }}
  brew "odin"
{{- end }}

{{- if .lang.python }}
  brew "python3"
  brew "uv"
{{- end }}

{{- if .lang.rust }}
  brew "rust"
  brew "rust-analyzer"
{{- end }}

{{- if .lang.zig }}
  brew "zig"
{{- end }}

EOF
