#!/usr/bin/env bash

set -euo pipefail

if ! hash brew >/dev/null; then
  bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

PACKAGES=(

################################################################################
# INPUT
################################################################################

{{- if .input.mouse.linear }}
  homebrew/cask/linearmouse
{{- end }}

################################################################################
# UI
################################################################################

{{- if .ui.night_shift.enabled }}
  smudge/smudge/nightlight
{{- end }}

################################################################################
# Apps
################################################################################

{{- if index .app "1password" }}
  homebrew/cask/1password
{{- end }}

{{- if index .app "anki" }}
  homebrew/cask/anki
{{- end }}

{{- if .app.bash }}
  bash
{{- end }}

{{- if .app.bat }}
  bat
{{- end }}

{{- if .app.docker }}
  homebrew/cask/docker-desktop
  lazydocker
{{- end }}

{{- if .app.exercism }}
  exercism
{{- end }}

{{- if .app.eza }}
  eza
  vivid
{{- end }}

{{- if .app.fd }}
  fd
{{- end }}

{{- if .app.ghostty }}
  homebrew/cask/ghostty
{{- end }}

{{- if .app.git }}
  git
  git-delta
  git-ignore
  codeberg-cli
  gh
  lazygit
{{- end }}

{{- if .app.helium }}
  homebrew/cask/helium-browser
{{- end }}

{{- if .app.jq }}
  jaq
{{- end }}

{{- if and .app.ghostty (not .terminal.font.pragmata) }}
  homebrew/cask-fonts/font-iosevka-ss08
{{- end }}

{{- if .app.mpv }}
  mpv
  yt-dlp
  aria2
{{- end }}

{{- if .app.neovim }}
  neovim
  tree-sitter-cli
  node
{{- end }}

{{- if .app.obsidian }}
  homebrew/cask/obsidian
  homebrew/cask/font-overpass
{{- end }}

{{- if .app.procs }}
  procs
{{- end }}

{{- if .app.ripgrep }}
  ripgrep
{{- end }}

{{- if .app.sd }}
  sd
{{- end }}

{{- if .app.zsh }}
  fzf
{{- end }}

################################################################################
# Programming Languages
################################################################################

{{- if .lang.cpp }}
  meson
{{- end }}

{{- if .lang.java }}
  maven
  openjdk
{{- end }}

{{- if .lang.python }}
  uv
{{- end }}

{{- if .lang.rust }}
  rustup
{{- end }}

{{- if .lang.zig }}
  zig
{{- end }}

)

echo "${PACKAGES[@]}" | xargs -r brew install --quiet
