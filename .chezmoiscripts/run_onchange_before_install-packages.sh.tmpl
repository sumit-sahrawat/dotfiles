#!/usr/bin/env bash

set -euo pipefail

if ! hash brew >/dev/null; then
  bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

PACKAGES=(

{{- if .input.mouse.linear }}
  homebrew/cask/linearmouse
{{- end }}

{{- if .app.zsh }}
  fzf
  catppuccin/tap/whiskers
{{- end }}

{{- if .app.git }}
  git
  git-delta
  git-ignore
  gh
  lazygit
{{- end }}

{{- if .app.kitty }}
  homebrew/cask/kitty
{{- end }}

{{- if and .app.kitty (not .kitty.font.pragmata) }}
  homebrew/cask-fonts/font-iosevka-ss08
{{- end }}

{{- if index .app "1password" }}
  homebrew/cask/1password
{{- end }}

{{- if index .app "anki" }}
  homebrew/cask/anki
{{- end }}

{{- if .app.bat }}
  bat
{{- end }}

{{- if .app.docker }}
  homebrew/cask/docker-desktop
  lazydocker
{{- end }}

{{- if .app.eza }}
  eza
{{- end }}

{{- if .app.fd }}
  fd
{{- end }}

{{- if .app.jq }}
  jaq
{{- end }}

{{- if .app.mpv }}
  mpv
  yt-dlp
  aria2
{{- end }}

{{- if .app.neovim }}
  neovim
{{- end }}

{{- if .app.obsidian }}
  homebrew/cask/obsidian
  homebrew/cask/font-overpass
{{- end }}

{{- if .app.procs }}
  procs
{{- end }}

{{- if .app.ripgrep }}
  ripgrep
{{- end }}

{{- if .app.sd }}
  sd
{{- end }}

{{- if .lang.python }}
  uv
{{- end }}

{{- if .lang.rust }}
  rustup
{{- end }}

)

echo "${PACKAGES[@]}" | xargs -r brew install --quiet
