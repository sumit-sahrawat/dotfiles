{{- if eq .chezmoi.os "linux" -}}

#!/usr/bin/env bash

set -euo pipefail

if ! command -v nix >/dev/null; then
  sh <(curl -L https://nixos.org/nix/install) --no-daemon
  . ~/.nix-profile/etc/profile.d/nix.sh
fi

PACKAGES=(

  ################################################################################
  # Core CLI Tools
  ################################################################################

  bat
  btop
  delta
  difftastic
  duf
  dust
  eza
  fd
  fzf
  imagemagick
  just
  mprocs
  numbat
  procs
  ripgrep
  sd
  vivid
  yazi

  ################################################################################
  # Apps
  ################################################################################

  {{- if .app.direnv }}
  direnv
  {{- end }}

  {{- if .app.git }}
  git
  gh
  lazygit
  {{- end }}

  {{- if .app.neovim }}
  neovim
  tree-sitter
  nodejs
  {{- end }}

  ################################################################################
  # Programming Languages
  ################################################################################

  {{- if .lang.bash }}
  bash
  {{- end }}

  {{- if .lang.cpp }}
  cmake
  meson
  {{- end }}

  {{- if .lang.java }}
  maven
  jdk
  {{- end }}

  {{- if .lang.javascript }}
  nodejs
  nodePackages.npm
  {{- end }}

  {{- if .lang.jq }}
  jq
  {{- end }}

  {{- if .lang.python }}
  python3
  uv
  {{- end }}

  {{- if .lang.rust }}
  rustc
  rust-analyzer
  {{- end }}

  {{- if .lang.zig }}
  zig
  {{- end }}

)

for pkg in "${PACKAGES[@]}"; do
  nix profile install "nixpkgs#${pkg}"
done

{{- end -}}
